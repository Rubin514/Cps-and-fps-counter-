{
  "namespace": "hud",

  "cps_fps_panel": {
    "type": "panel",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "offset": [5, 5],
    "size": [100, 40],
    "controls": [
      {
        "counter_text": {
          "type": "label",
          "color": [1.0, 1.0, 1.0],
          "text": "FPS: 60\nCPS: 0",
          "shadow": true,
          "font_size": "normal"
        }
      }
    ]
  },

  // This forces Minecraft to inject your panel into the actual game HUD
  "root_panel": {
    "modifications": [
      {
        "array_name": "controls",
        "operation": "insert_back",
        "value": {
          "cps_fps_panel@hud.cps_fps_panel": {}
        }
      }
    ]
  }
}
